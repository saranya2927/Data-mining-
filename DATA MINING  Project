import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
from scipy import stats
from sklearn.cluster import KMeans
from sklearn.linear_model import LinearRegression

# -------------------------------
# LOAD DATASET
# -------------------------------
print("\n========== DATA LOADING ==========\n")
df = pd.read_csv('Attendance_Prediction_Modified.csv')
print("First 5 Rows:\n", df.head())

# -------------------------------
# 1. MISSING VALUES
# -------------------------------
print("\n========== MISSING VALUES ==========\n")

print("Missing Values Before Cleaning:\n")
print(df.isnull().sum())

# Heatmap Before
plt.figure(figsize=(10,6))
sns.heatmap(df.isnull(), cbar=False)
plt.title("Missing Values Heatmap (Before Cleaning)")
plt.show()

# Fill missing values
df_clean = df.fillna(df.median(numeric_only=True))

print("\nMissing Values After Cleaning:\n")
print(df_clean.isnull().sum())

# Heatmap After
plt.figure(figsize=(10,6))
sns.heatmap(df_clean.isnull(), cbar=False)
plt.title("Missing Values Heatmap (After Cleaning)")
plt.show()

# -------------------------------
# 2. DUPLICATE DATA
# -------------------------------
print("\n========== DUPLICATE DATA ==========\n")

duplicates = df.duplicated().sum()
print("Duplicate Rows Before Cleaning:", duplicates)

plt.figure()
plt.bar(["Before"], [duplicates])
plt.title("Duplicate Rows Before Cleaning")
plt.show()

# Remove duplicates
df_clean = df_clean.drop_duplicates()

duplicates_after = df_clean.duplicated().sum()
print("Duplicate Rows After Cleaning:", duplicates_after)

plt.figure()
plt.bar(["After"], [duplicates_after])
plt.title("Duplicate Rows After Cleaning")
plt.show()

# -------------------------------
# 3. OUTLIER DETECTION
# -------------------------------
print("\n========== OUTLIER DETECTION ==========\n")

numeric_cols = df_clean.select_dtypes(include=['float64','int64']).columns

# Before Cleaning
for col in numeric_cols:
    plt.figure()
    sns.boxplot(x=df[col])
    plt.title(f"{col} - Before Outlier Removal")
    plt.show()

# Remove Outliers using Z-score
for col in numeric_cols:
    z = stats.zscore(df_clean[col])
    df_clean = df_clean[(abs(z) < 3)]

# After Cleaning
for col in numeric_cols:
    plt.figure()
    sns.boxplot(x=df_clean[col])
    plt.title(f"{col} - After Outlier Removal")
    plt.show()

# -------------------------------
# 4. CORRELATION ANALYSIS
# -------------------------------
print("\n========== CORRELATION ANALYSIS ==========\n")

corr = df_clean.corr(numeric_only=True)
print("Correlation Matrix:\n", corr)

plt.figure(figsize=(8,6))
sns.heatmap(corr, annot=True)
plt.title("Correlation Heatmap")
plt.show()
